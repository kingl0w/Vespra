# ─── REQUIRED ─────────────────────────────────────────────────
# These three must be filled in or the stack will not boot.

# Master password for the keymaster keystore. Min 16 chars.
# CHANGE THIS — losing it means losing access to your wallets.
VESPRA_MASTER_PASSWORD=change-me-to-something-long-and-random

# Bearer token for keymaster <-> gateway auth. Min 16 chars.
# Generate one with:  openssl rand -base64 32
VESPRA_KM_AUTH_TOKEN=

# LLM API key — DeepSeek is by far the cheapest and works fine.
# Sign up: https://platform.deepseek.com
LLM_API_KEY=

# ─── LLM ──────────────────────────────────────────────────────
LLM_PROVIDER=deepseek                       # deepseek | openai | anthropic
LLM_MODEL=deepseek-chat                     # match the provider
LLM_BASE_URL=https://api.deepseek.com       # change for openai/anthropic

# ─── RPC URLs ─────────────────────────────────────────────────
# Set the chains you actually want to use. Free RPC works for testnets;
# for mainnet, use Alchemy / Infura / QuickNode.
# Sign up: https://dashboard.alchemy.com
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org
RPC_URL_ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc
RPC_URL_BASE=
RPC_URL_ARBITRUM=
RPC_URL_ETHEREUM=
RPC_URL_OPTIMISM=

# ─── DEX Routing ──────────────────────────────────────────────
# Use ParaSwap (no API key, no KYC) OR 1inch (needs KYC).
# Default is ParaSwap.
PARASWAP_MODE=true
ONEINCH_API_KEY=

# ─── Treasury (optional) ──────────────────────────────────────
# Gnosis Safe address. Used as the sweep target and treasury for fees.
# Leave blank if you don't want fee collection.
GNOSIS_SAFE_ADDRESS=
FEE_RATE_BPS=500

# ─── Safety ───────────────────────────────────────────────────
# Set to true ONLY when you're ready to broadcast real transactions.
# false = dry-run mode: every step runs but nothing is signed/broadcast.
VESPRA_AUTO_EXECUTE_ENABLED=false

# ─── Price Oracles ────────────────────────────────────────────
VESPRA_PRICE_ORACLE=defillama
VESPRA_PRICE_ORACLE_FALLBACK=coingecko

# ─── Logging ──────────────────────────────────────────────────
RUST_LOG=info                               # info | debug | trace
