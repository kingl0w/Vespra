# ── LLM ─────────────────────────────────────────────
LLM_API_KEY=           # Required. DeepSeek (cheapest), OpenAI, or Anthropic
LLM_PROVIDER=deepseek  # deepseek | openai | anthropic

# ── RPC / Chain ──────────────────────────────────────
ALCHEMY_API_KEY=       # Required. Free tier at https://dashboard.alchemy.com

# ── DEX Routing ──────────────────────────────────────
ONEINCH_API_KEY=       # Required unless PARASWAP_MODE=true. https://portal.1inch.dev (KYC required)
PARASWAP_MODE=false    # Set true to use Paraswap instead of 1inch (no KYC)

# ── Custody ──────────────────────────────────────────
GNOSIS_SAFE_ADDRESS=   # Required. Your Gnosis Safe multisig address
VESPRA_KM_AUTH_TOKEN=  # Auto-generated by Keymaster on first run — leave blank initially

# ── Trade Up (optional) ───────────────────────────────
VESPRA_TRADE_UP_TARGET_GAIN_PCT=15
VESPRA_TRADE_UP_STOP_LOSS_PCT=5
VESPRA_TRADE_UP_MAX_ETH=0.02
VESPRA_TRADE_UP_GAS_RESERVE_ETH=0.01

# ── Infrastructure ────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
GATEWAY_PORT=9001
KEYMASTER_URL=http://127.0.0.1:9100
NULLBOILER_URL=http://127.0.0.1:9090
