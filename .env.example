# ─── Network ──────────────────────────────────────────────
VESPRA_NETWORK_MODE=testnet

# ─── Fees (optional, see README) ──────────────────────────
FEES_ENABLED=false
# TREASURY_ADDRESS=0x...   # required if FEES_ENABLED=true

# ─── Chains ───────────────────────────────────────────────
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org
RPC_URL_ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc
# RPC_URL_BASE=                  # mainnet, uncomment and fill
# RPC_URL_ARBITRUM=              # mainnet

# ─── Keymaster ────────────────────────────────────────────
KEYMASTER_MASTER_PASSWORD=    # generate via scripts/init.sh
KEYMASTER_BEARER_TOKEN=       # generate via scripts/init.sh

# ─── Gateway ──────────────────────────────────────────────
VESPRA_REDIS_URL=redis://redis:6379
VESPRA_KEYMASTER_URL=http://keymaster:9100
VESPRA_AUTO_RESUME_GOALS=true
VESPRA_MAX_TX_PER_HOUR=100
# VESPRA_MAX_GLOBAL_WALLET_VALUE_ETH=5.0

# ─── Notifications (optional) ─────────────────────────────
# VESPRA_TELEGRAM_BOT_TOKEN=
# VESPRA_TELEGRAM_CHAT_ID=

# ─── LLM ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
