# Network mode: "testnet" or "mainnet"
# testnet: relaxed risk gates, synthetic fallback pools when data sparse
# mainnet: strict risk gates, no synthetic data, full safety checks
VESPRA_NETWORK_MODE=testnet

# Global cap across all burner wallets (ETH). Unset = no global cap.
# VESPRA_MAX_GLOBAL_WALLET_VALUE_ETH=5.0

# Max executor-initiated TXs per hour (gateway-wide). Unset = no limit.
VESPRA_MAX_TX_PER_HOUR=100
