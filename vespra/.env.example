# ── LLM Provider ──────────────────────────────────────────
LLM_PROVIDER=deepseek          # deepseek | openai | anthropic
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat        # deepseek-chat | gpt-4o | claude-sonnet-4-20250514

# ── Chain / RPC ───────────────────────────────────────────
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# ── Keymaster ─────────────────────────────────────────────
KEYMASTER_MASTER_PASSWORD=change_this_to_something_strong
KEYMASTER_BEARER_TOKEN=change_this_too
KEYMASTER_PORT=9100

# ── Gateway ───────────────────────────────────────────────
GATEWAY_PORT=9000

# ── NullBoiler ────────────────────────────────────────────
NULLBOILER_PORT=9090

# ── Proxy ─────────────────────────────────────────────────
PROXY_PORT=9200

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Vespra Fee ────────────────────────────────────────────
VESPRA_FEE_ADDRESS=0x0000000000000000000000000000000000000000
VESPRA_FEE_BPS=30              # 30 = 0.3%
