# Vespra Keymaster — example environment variables
# Copy to .env and fill in values before starting.

VESPRA_MASTER_PASSWORD=          # required, >=16 chars — encrypts wallet keys at rest
VESPRA_KM_AUTH_TOKEN=            # required, >=16 chars — bearer token for protected routes
VESPRA_KM_HOST=127.0.0.1
VESPRA_KM_PORT=9100
VESPRA_KM_DB=keymaster.db

# RPC URLs — at least one chain required
VESPRA_RPC_BASE=
VESPRA_RPC_BASE_SEPOLIA=
VESPRA_RPC_ARBITRUM=
VESPRA_RPC_ETHEREUM=

# Safe addresses for sweep-to-safe
VESPRA_SAFE_BASE=
VESPRA_SAFE_BASE_SEPOLIA=

# Fees — disabled by default (free/self-hosted mode).
# Set FEES_ENABLED=true to enable the managed-tier fee model.
# When enabled, TREASURY_ADDRESS is required — set it to your own wallet.
# Boot will refuse to start if FEES_ENABLED=true without a valid TREASURY_ADDRESS.
FEES_ENABLED=false
# TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
