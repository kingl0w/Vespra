# Vespra Gateway â€” LLM provider config
# Copy to .env and fill in values. The gateway reads these via os.environ.

# Required: which LLM backend to use (deepseek | openai | anthropic)
LLM_PROVIDER=deepseek

# Optional: override the default model for the chosen provider
# Defaults: deepseekâ†’deepseek-chat, openaiâ†’gpt-4o-mini, anthropicâ†’claude-haiku-4-5-20251001
# LLM_MODEL=deepseek-chat

# Optional: API key (if not set, agents fall back to per-workspace nullclaw config)
# LLM_API_KEY=sk-...

# Keymaster auth token
# VESPRA_KM_AUTH_TOKEN=

# Alchemy webhook secret (for /webhooks/alchemy HMAC verification)
# ALCHEMY_WEBHOOK_SECRET=

# 1inch API key (for Trader agent swap quotes)
# ONEINCH_API_KEY=
