# ── LLM Provider ──────────────────────────────────────────────────
# Supported: deepseek | openai | anthropic
LLM_PROVIDER=deepseek
# Model override (optional — defaults to provider's recommended model)
# deepseek:  deepseek-chat
# openai:    gpt-4o-mini
# anthropic: claude-haiku-4-5-20251001
LLM_MODEL=
# API key for the chosen provider
# For deepseek: https://platform.deepseek.com/api_keys
# For openai:   https://platform.openai.com/api_keys
# For anthropic: https://console.anthropic.com/api-keys
LLM_API_KEY=your_key_here

# ── 1inch Aggregator ──────────────────────────────────────────────
ONEINCH_API_KEY=your_key_here

# ── Keymaster ─────────────────────────────────────────────────────
VESPRA_KM_AUTH_TOKEN=your_token_here

# ── Alchemy ───────────────────────────────────────────────────────
ALCHEMY_API_KEY=your_key_here
ALCHEMY_WEBHOOK_SECRET=your_webhook_secret_here

# ── Yield Rotation ────────────────────────────────────────────────
# Enable autonomous yield rotation (requires STRATEGY_WALLET_MAP with yield: entry)
YIELD_AUTO_ROTATE_ENABLED=false
# Rotate when new yield beats current by this % (default 1%)
YIELD_AUTO_ROTATE_THRESHOLD_PCT=1.0
# Max ETH per rotation
YIELD_MAX_ROTATE_ETH=0.5
# Always keep this much ETH for gas
YIELD_GAS_RESERVE_ETH=0.01

# ── Sniper Auto-Entry ─────────────────────────────────────────────
# Enable autonomous sniper entries (default: false — explicit opt-in)
SNIPER_AUTO_ENTRY_ENABLED=false
# Max ETH per sniper entry
SNIPER_MAX_ENTRY_ETH=0.05
# Minimum pool TVL to enter (hard floor)
SNIPER_MIN_TVL=50000
# Exit trigger: if TVL drops this % post-entry, Sentinel fires exit DAG
SNIPER_EXIT_TVL_DROP_PCT=30.0

# ── Trade Up Loop (VES-44) ───────────────────────────────────────
# Enable the Scout→Risk→Trader→Executor compounding loop
TRADE_UP_ENABLED=false
# Max ETH per trade-up cycle
TRADE_UP_MAX_ETH=0.02
# Minimum expected gain % to execute a swap
TRADE_UP_MIN_GAIN_PCT=0.5
# Seconds between cycles
TRADE_UP_CYCLE_INTERVAL_SEC=300
# Max cycles (0 = unlimited)
TRADE_UP_MAX_CYCLES=0
# Compound gains into next cycle capital
TRADE_UP_COMPOUND=true
# Stop-loss: halt loop if drawdown exceeds this %
TRADE_UP_STOP_LOSS_PCT=5.0
